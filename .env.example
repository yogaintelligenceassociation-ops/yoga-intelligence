# ──────────────────────────────────────────────────────────────────────────────
# Yoga Intelligence — environment variables
# Copy this file to `.env` for local development.
# Set these in the Vercel dashboard for production.
# Never commit `.env` to version control.
# ──────────────────────────────────────────────────────────────────────────────

# ─── Backend (Python serverless, /api/*) ──────────────────────────────────

# MongoDB connection string (Atlas recommended for production).
# Atlas: https://www.mongodb.com/cloud/atlas — free M0 tier works for hobby use.
MONGO_URL=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/?retryWrites=true&w=majority

# Database name used for OTPs and users. (Chats are ephemeral — never stored.)
DB_NAME=yoga_intelligence

# Fast2SMS API key for sending OTPs (https://www.fast2sms.com/).
# Leave blank during development — the backend will return the OTP in the
# response payload (dev_otp) so you can test the auth flow without SMS.
FAST2SMS_API_KEY=

# Google Gemini API key (free tier works for Gemini 2.5 Flash).
# Get one at https://aistudio.google.com/apikey
GEMINI_API_KEY=

# Long, random string used to sign JWTs. REQUIRED in production.
# Generate with: openssl rand -hex 64
JWT_SECRET_KEY=

# OPTIONAL — Google Sheet logging of new sign-ups (name + phone only).
# Create a Google Apps Script Web App bound to a Sheet (see README) and paste
# its /exec URL here. Leave blank to disable. Failures never block login.
GOOGLE_SHEET_WEBHOOK_URL=

# Comma-separated allow-list of origins. Use "*" only in development.
# Example: CORS_ORIGINS=https://yourdomain.com,https://www.yourdomain.com
CORS_ORIGINS=*

# ─── Frontend (Create React App, REACT_APP_* are inlined at build time) ───

# Base URL for API calls. Leave blank to use a relative `/api` path (works on
# Vercel because the frontend and serverless functions share the same domain).
REACT_APP_API_BASE_URL=

# Local dev only — used by Craco's dev-server proxy so /api/* hits your local
# uvicorn server instead of crashing.
API_PROXY_TARGET=http://localhost:8000
